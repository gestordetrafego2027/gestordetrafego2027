# --- SITE CONFIGURATION ---
# The public URL of your deployed application (required for SEO and canonical links)
# Example: https://app.housemazzutti.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- SERVER CONFIGURATION ---
# The port the application will run on in the container
PORT=3000
# Node environment (development, production, test)
NODE_ENV=production

# --- DATABASE CONFIGURATION ---
# Path to the SQLite database file
DATABASE_PATH=./database.db

# --- SECURITY & ANALYTICS (Optional) ---
# Add your Google Analytics ID, API Keys, or Secrets below
# NEXT_PUBLIC_GA_ID=
# API_SECRET_KEY=
